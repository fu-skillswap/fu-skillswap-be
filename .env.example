# ============================================================
#  SkillSwap Backend — Environment Variables Template
#  Copy to .env and fill in real values before deploying.
#  NEVER commit the real .env file to version control.
# ============================================================

# Active Spring profile: use "prod" on VPS. Switch to "dev" only for local development.
SPRING_PROFILES_ACTIVE=prod
JWT_ISSUER=skillswap
JWT_AUDIENCE=skillswap-api

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=jdbc:postgresql://localhost:5444/skillswapdb
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=change-me

# Used by docker-compose postgres service
POSTGRES_DB=skillswapdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# ── JWT & Security ───────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET_KEY=replace-with-a-base64-encoded-secret-at-least-32-bytes
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# Cursor pagination encryption keys (base64-encoded 32-byte AES + HMAC keys)
# Generate with: openssl rand -base64 32
# IMPORTANT: Override both in production — defaults in application.yaml are NOT safe for prod
CURSOR_AES_KEY=
CURSOR_HMAC_KEY=

# ── Google OAuth / Calendar ──────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=
# 32-byte AES encryption key for storing Google tokens (base64-encoded)
GOOGLE_TOKEN_ENCRYPTION_KEY=
GOOGLE_TOKEN_ENCRYPTION_KEY_VERSION=1

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Replace with your actual frontend domain in prod.
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ── Admin ────────────────────────────────────────────────────
# Comma-separated list of emails that will be auto-assigned SYSTEM_ADMIN role on startup
SYSTEM_ADMIN_EMAILS=

# ── PayOS (Payment Gateway) ──────────────────────────────────
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
# Replace with your actual frontend return URLs in prod
PAYOS_RETURN_URL=http://localhost:3000/payment/return
PAYOS_CANCEL_URL=http://localhost:3000/payment/cancel
PAYOS_WEBHOOK_URL=
PAYOS_WEBHOOK_SECRET=

# ── Email (Brevo SMTP) ───────────────────────────────────────
APPLICATION_MAIL_ENABLED=false
APPLICATION_MAIL_FROM=no-reply@skillswap.asia
SPRING_MAIL_HOST=smtp-relay.brevo.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# ── Storage Gateway (Cloudflare R2 / AWS S3 compatible) ──────
# Set STORAGE_ENABLED=true and fill credentials to enable file upload for mentor verification
STORAGE_ENABLED=false
STORAGE_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=skillswap
STORAGE_REGION=auto
STORAGE_PUBLIC_URL_PREFIX=https://cdn.skillswap.com
STORAGE_DOCUMENTS_PREFIX=skillswap/verification-documents

# ── RabbitMQ (internal, not exposed publicly) ────────────────
RABBITMQ_DEFAULT_USER=skillswap
RABBITMQ_DEFAULT_PASS=change-me

# ── Swagger / OpenAPI ────────────────────────────────────────
# Set to false in production to block public Swagger access
APPLICATION_SWAGGER_ENABLED=false

# ── Database Schema Management ───────────────────────────────
# PROD: Set FLYWAY_ENABLED=true to run migrations automatically on startup
# DEV:  Leave false; schema is managed by Hibernate DDL
FLYWAY_ENABLED=true
# PROD: validate | DEV: create or update — DO NOT use "create" or "update" in prod
HIBERNATE_DDL_AUTO=validate
