SPRING_PROFILES_ACTIVE=dev

DATABASE_URL=jdbc:postgresql://localhost:5444/skillswapdb
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=123456

POSTGRES_DB=skillswapdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456

JWT_SECRET_KEY=replace-with-a-base64-encoded-secret-at-least-32-bytes
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

GOOGLE_CLIENT_ID=
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# PayOS Hosted Payment Link
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_RETURN_URL=http://localhost:3000/payment/return
PAYOS_CANCEL_URL=http://localhost:3000/payment/cancel
PAYOS_WEBHOOK_URL=
PAYOS_WEBHOOK_SECRET=

# Brevo SMTP / Booking Email Notification
APPLICATION_MAIL_ENABLED=false
APPLICATION_MAIL_FROM=no-reply@skillswap.asia
SPRING_MAIL_HOST=smtp-relay.brevo.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# Bật 1 trong 2 provider upload cho minh chứng mentor:
# - Cloudinary: bật CLOUDINARY_ENABLED=true và điền đủ 3 biến bên dưới
# - R2: bật R2_ENABLED=true và điền đủ nhóm biến R2 bên dưới
CLOUDINARY_ENABLED=false
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Swagger / OpenAPI
APPLICATION_SWAGGER_ENABLED=false

FLYWAY_ENABLED=false
HIBERNATE_DDL_AUTO=update
